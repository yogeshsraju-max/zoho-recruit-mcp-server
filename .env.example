# ---- Zoho OAuth credentials (required) ----
# Created in the Zoho API console: https://api-console.zoho.com/
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# ---- Zoho data center region ----
# One of: com (US), eu, in, au, jp, ca
ZOHO_REGION=com

# Optional explicit overrides. Leave blank to derive from ZOHO_REGION.
# ZOHO_BASE_URL=https://recruit.zoho.com/recruit/v2
# ZOHO_ACCOUNTS_URL=https://accounts.zoho.com

# ---- Transport / server ----
# stdio (Claude Desktop) | http (cloud / Inspector)
MCP_TRANSPORT=stdio
HTTP_HOST=0.0.0.0
HTTP_PORT=8000

# ---- Behaviour ----
LOG_LEVEL=INFO
REQUEST_TIMEOUT_SECONDS=30
MAX_RETRIES=3
RATE_LIMIT_PER_MINUTE=100
